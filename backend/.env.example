# Server
PORT=3005
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173

# JWT — generate with: openssl rand -hex 64
JWT_SECRET=change-me-access-token-secret
REFRESH_TOKEN_SECRET=change-me-refresh-token-secret

# Encryption master key — generate with: openssl rand -hex 32
# Used to wrap signing private keys and encrypt PII columns (serial, IMEI)
ROOT_ENC_KEY_HEX=change-me-64-char-hex-string-here-aabbccddee112233445566778899

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=app
MYSQL_PASSWORD=app
MYSQL_DATABASE=dealapprover
# DB_ROOT_PASSWORD only used by docker-compose
DB_ROOT_PASSWORD=rootpassword

# AWS S3
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_UPLOADS=da-uploads-dev
AWS_S3_BUCKET_PHOTOS=da-photos-dev
AWS_S3_BUCKET_RENDERS=da-renders-dev

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_BUSINESS_MONTHLY=price_...

# Resend
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@dealapprover.com

# App URLs
APP_URL=http://localhost:5173
API_URL=http://localhost:3005

# Google OAuth (optional for MVP)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
